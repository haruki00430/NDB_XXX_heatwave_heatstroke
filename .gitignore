.serena/
.env.temp
nul

03_Analysis/**/logs/*.log

# GitHub 単一ファイル 100MB 制限（大きいジオデータは LFS かローカルのみ）
*.geojson
*.shp
*.dbf
*.shx
*.prj

# 大容量アーカイブ・生データ（再ダウンロードで再現）
*.zip
*.7z
*.pkl

# 国土数値情報など数百 MB 超（GitHub 100MB 制限）
data/raw/MLIT_N03/
**/MLIT_N03/
data/raw/**/*.xml
data/temp/**/*.xml

